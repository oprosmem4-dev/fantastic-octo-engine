# ──────────────────────────────────────────────────
# .env.example — скопируйте в .env и заполните
# ──────────────────────────────────────────────────

# ── Главный бот ────────────────────────────────────
BOT_TOKEN=1234567890:AABBccddEEFFggHH        # токен от @BotFather
OWNER_ID=123456789                            # ваш Telegram ID

# ── База данных PostgreSQL ─────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tgsaas

# ── Redis (для FSM в продакшене) ───────────────────
REDIS_URL=redis://localhost:6379/0

# ── CryptoBot (опционально) ────────────────────────
CRYPTOBOT_TOKEN=                              # токен из @CryptoBot → My Apps
CRYPTOBOT_WEBHOOK_SECRET=                     # секрет для проверки webhook

# ── TON кошелёк (опционально) ─────────────────────
TON_WALLET=                                   # ваш TON-адрес

# ── FastAPI ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET=change_me_to_random_string         # любой случайный секрет

# ── Ссылка на главного бота (для зеркал) ──────────
MAIN_BOT_LINK=https://t.me/your_main_bot
